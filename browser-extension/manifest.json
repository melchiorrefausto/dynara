{
  "manifest_version": 3,
  "name": "Dynara",
  "version": "0.2.0",
  "description": "AI-native interface runtime — customize any software's UI",
  "permissions": ["activeTab", "tabs", "storage", "scripting", "sidePanel"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "dist/background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["dist/content.js"],
      "run_at": "document_idle"
    }
  ],
  "side_panel": {
    "default_path": "dist/sidepanel.html"
  },
  "action": {
    "default_title": "Dynara"
  }
}
