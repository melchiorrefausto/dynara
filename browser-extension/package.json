{
  "name": "dynara-browser-extension",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "npm run build:bg && npm run build:content && npm run build:popup",
    "build:bg": "BUILD_TARGET=bg vite build",
    "build:content": "BUILD_TARGET=content vite build",
    "build:popup": "BUILD_TARGET=popup vite build",
    "dev": "npm run build:bg && npm run build:content && npm run build:popup -- --watch"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.268",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "typescript": "^5.4.0",
    "vite": "^5.4.0",
    "vite-plugin-singlefile": "^2.0.0"
  },
  "dependencies": {
    "react": "^18.3.0",
    "react-dom": "^18.3.0"
  }
}
