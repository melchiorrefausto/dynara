# ─── Supabase ────────────────────────────────────────────────────────────────
# Find these in your Supabase project: Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# ─── Figma OAuth ─────────────────────────────────────────────────────────────
# Create an OAuth app at https://www.figma.com/developers/apps
# Redirect URI to add: http://localhost:3001/api/connectors/figma/callback
FIGMA_CLIENT_ID=your-figma-client-id
FIGMA_CLIENT_SECRET=your-figma-client-secret

# ─── App ─────────────────────────────────────────────────────────────────────
# Base URL used to build OAuth redirect URIs.
# Local dev: http://localhost:3001 (or whatever port Next.js picks)
# Production: https://yourdomain.com
NEXT_PUBLIC_APP_URL=http://localhost:3001

# ─── AI (optional) ───────────────────────────────────────────────────────────
# Used by /api/generate-workspace for AI workspace generation.
ANTHROPIC_API_KEY=your-anthropic-api-key
