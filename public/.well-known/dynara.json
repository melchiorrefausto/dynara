{
  "name": "BeFour",
  "color": "#7c3aed",
  "appId": "befour",
  "version": "1.0.0",
  "panels": [
    {
      "id": "navigation",
      "label": "Navigation",
      "selector": "header"
    },
    {
      "id": "hero",
      "label": "Hero",
      "selector": "[data-dynara-panel='hero']"
    },
    {
      "id": "hero-search",
      "label": "Hero Search",
      "selector": "[data-dynara-panel='hero-search']"
    },
    {
      "id": "tool-categories",
      "label": "Tool Categories",
      "selector": "[data-dynara-panel='tool-categories']"
    },
    {
      "id": "main-content",
      "label": "Main Content",
      "selector": "main"
    },
    {
      "id": "footer",
      "label": "Footer",
      "selector": "footer"
    }
  ],
  "surfaces": [
    {
      "id": "navigation",
      "label": "Navigation",
      "type": "navigation",
      "selector": "header",
      "side": "top",
      "required": false,
      "hideable": true,
      "movable": false,
      "resizable": false
    },
    {
      "id": "hero",
      "label": "Hero",
      "type": "content",
      "selector": "[data-dynara-panel='hero']",
      "required": false,
      "hideable": true,
      "movable": false,
      "resizable": false,
      "description": "The first viewport hero area on the BeFour home page."
    },
    {
      "id": "hero-search",
      "label": "Hero Search",
      "type": "toolbar",
      "selector": "[data-dynara-panel='hero-search']",
      "required": false,
      "hideable": true,
      "movable": false,
      "resizable": false,
      "description": "The primary hero input and call to action."
    },
    {
      "id": "tool-categories",
      "label": "Tool Categories",
      "type": "content",
      "selector": "[data-dynara-panel='tool-categories']",
      "required": false,
      "hideable": true,
      "movable": false,
      "resizable": false,
      "description": "The homepage tool category grid."
    },
    {
      "id": "main-content",
      "label": "Main Content",
      "type": "panel",
      "selector": "main",
      "required": true,
      "hideable": false,
      "movable": false,
      "resizable": false
    },
    {
      "id": "footer",
      "label": "Footer",
      "type": "content",
      "selector": "footer",
      "side": "bottom",
      "required": false,
      "hideable": true,
      "movable": false,
      "resizable": false
    }
  ],
  "views": [
    {
      "id": "default",
      "label": "Default",
      "panels": [
        "navigation",
        "hero",
        "hero-search",
        "tool-categories",
        "main-content",
        "footer"
      ]
    },
    {
      "id": "focus-content",
      "label": "Focus content",
      "panels": [
        "hero",
        "hero-search",
        "tool-categories",
        "main-content"
      ]
    },
    {
      "id": "hero-focus",
      "label": "Hero focus",
      "panels": [
        "navigation",
        "main-content",
        "hero",
        "hero-search"
      ]
    },
    {
      "id": "tool-discovery",
      "label": "Tool discovery",
      "panels": [
        "navigation",
        "main-content",
        "hero",
        "hero-search",
        "tool-categories",
        "footer"
      ]
    },
    {
      "id": "reading",
      "label": "Reading",
      "panels": [
        "hero",
        "hero-search",
        "tool-categories",
        "main-content",
        "footer"
      ]
    },
    {
      "id": "minimal",
      "label": "Minimal",
      "panels": [
        "main-content"
      ]
    }
  ],
  "actions": [
    {
      "id": "reading-large-text",
      "label": "Toggle larger text",
      "description": "Increase main content text size and line height for reading.",
      "kind": "mutation"
    },
    {
      "id": "reading-width",
      "label": "Toggle reading width",
      "description": "Constrain main content width for a focused reading layout.",
      "kind": "mutation"
    },
    {
      "id": "high-contrast",
      "label": "Toggle high contrast",
      "description": "Increase contrast on the current page.",
      "kind": "mutation"
    },
    {
      "id": "reset-reading",
      "label": "Reset reading changes",
      "description": "Remove Dynara reading text, width, and contrast changes.",
      "kind": "mutation"
    },
    {
      "id": "theme-ocean",
      "label": "Apply Ocean theme",
      "description": "Apply a cool blue-green color system.",
      "kind": "mutation"
    },
    {
      "id": "theme-mono",
      "label": "Apply Mono theme",
      "description": "Apply a neutral grayscale color system.",
      "kind": "mutation"
    },
    {
      "id": "theme-sunset",
      "label": "Apply Sunset theme",
      "description": "Apply a warm red-orange color system.",
      "kind": "mutation"
    },
    {
      "id": "hero-showcase",
      "label": "Hero showcase",
      "description": "Turn the home hero into a larger premium landing section.",
      "kind": "mutation"
    },
    {
      "id": "hero-compact",
      "label": "Hero compact",
      "description": "Reduce hero height and tighten the headline/search spacing.",
      "kind": "mutation"
    },
    {
      "id": "hero-clean",
      "label": "Hero clean",
      "description": "Hide decorative hero glows, grid, and floating badges.",
      "kind": "mutation"
    },
    {
      "id": "hero-reset",
      "label": "Reset hero",
      "description": "Remove Dynara hero layout overrides.",
      "kind": "mutation"
    },
    {
      "id": "reset-interface",
      "label": "Reset interface",
      "description": "Remove Dynara theme, layout, and reading overrides.",
      "kind": "mutation"
    }
  ],
